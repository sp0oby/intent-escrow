# Copy to .env.local and fill in. NEXT_PUBLIC_* values ship to the browser.

# Public Sepolia JSON-RPC (used for reads + wallet tx submission).
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Deployed IntentEscrow contract on Sepolia (fill in after `forge script Deploy`).
NEXT_PUBLIC_INTENT_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: deployed MockERC20 (for the demo dropdown in the create form).
NEXT_PUBLIC_DEMO_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect Cloud project id (free at https://cloud.walletconnect.com).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
