# Copy this file to .env and fill in real values. Never commit .env.
# -----------------------------------------------------------------------------

# Sepolia JSON-RPC endpoint. Free options: Alchemy, Infura, Ankr, drpc, 1RPC.
# Example: https://eth-sepolia.g.alchemy.com/v2/<key>
SEPOLIA_RPC_URL=

# Deployer private key. Use a fresh, throw-away key for testnet only.
# Must be a hex string prefixed with 0x.
PRIVATE_KEY=

# Etherscan V2 API key (used for `forge verify-contract`).
ETHERSCAN_API_KEY=
